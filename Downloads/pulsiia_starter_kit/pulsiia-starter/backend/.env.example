# ═══════════════════════════════════════════════════════════════
# PULSIIA — Variables d'environnement
# Copie ce fichier en .env et adapte les valeurs
# ═══════════════════════════════════════════════════════════════

# ── Base de données ────────────────────────────────────────────
DATABASE_URL="postgresql://pulsiia:pulsiia_dev_pass@localhost:5432/pulsiia"

# ── Serveur ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── URLs ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ── JWT (RS256 — clés asymétriques) ───────────────────────────
# Génère les clés : npm run jwt:keys  (dans backend/)
# Option A — fichiers locaux (recommandé en dev) :
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_REFRESH_PRIVATE_KEY_PATH=./keys/jwt-refresh-private.pem
JWT_REFRESH_PUBLIC_KEY_PATH=./keys/jwt-refresh-public.pem
# Option B — PEM inline (prod / Docker, \\n pour les retours à la ligne) :
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_REFRESH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_REFRESH_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SSO Google (optionnel pour dev) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SSO Microsoft (optionnel) ──────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ── Email (au moins un fournisseur — invitation collaborateur, reset MDP, etc.) ─
# Resend recommandé : https://resend.com (gratuit jusqu'à 3000 emails/mois)
RESEND_API_KEY=
# Alternative SendGrid
SENDGRID_API_KEY=
# Mailjet (recommandé) — https://app.mailjet.com/account/apikeys
# En prod : API HTTPS (443), pas besoin du port 587.
MAILJET_API_KEY=
MAILJET_API_SECRET=
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
# Alias acceptés si vous préférez :
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Pulsiia <notifications@pulsiia.com>"

# ── Push Notifications VAPID ───────────────────────────────────
# Génère avec : npx web-push generate-vapid-keys
VAPID_EMAIL="admin@pulsiia.com"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Uploads ────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Signature électronique Yousign (eIDAS — prestataire français agréé) ─
# Sandbox : https://developers.yousign.com/ → créer une clé API
YOUSIGN_API_KEY=
YOUSIGN_BASE_URL=https://api-sandbox.yousign.app/v3
# electronic_signature | advanced_electronic_signature (recommandé RH) | qualified_electronic_signature
YOUSIGN_SIGNATURE_LEVEL=advanced_electronic_signature
YOUSIGN_AUTH_MODE=otp_email
# Webhook (optionnel) : https://votre-api/api/documents/webhooks/yousign

# ── RGPD ───────────────────────────────────────────────────────
TERMS_VERSION="1.0"
PRIVACY_VERSION="1.0"
DATA_RETENTION_DAYS=730

# ── Planning Hybride (3 couches : contraintes + optimiseur + Haiku) ─
# Clé API : https://console.anthropic.com/
# Haiku sert UNIQUEMENT à interpréter le langage naturel et expliquer le résultat (~0.02€/génération)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MODEL_OPTIMIZE=claude-haiku-4-5
PLANNING_AI_ENABLED=true
# Couche 1 — règles légales CHR (modifiables)
PLANNING_MAX_WEEKLY_HOURS=48
PLANNING_LEGAL_WEEKLY_HOURS=35
PLANNING_NIGHT_SURCHARGE=1.20
PLANNING_OT_RATE_1=1.25
PLANNING_OT_RATE_2=1.50
# Couche 3 — Claude Haiku (intentions + explications)
PLANNING_HAIKU_MODEL=claude-haiku-4-5
PLANNING_MAX_TOKENS_INTENT=512
PLANNING_MAX_TOKENS_EXPLAIN=300

# ── Rapports ROI (méthode réaliste — voir roi-engine.js) ───────
ROI_RH_HOURLY_COST=42
ROI_PAYROLL_ERROR_COST=95
ROI_MINUTES_SYNC_BATCH=32
ROI_MINUTES_EXTRA_SYNC=8
ROI_MAX_SYNC_CREDITS=4
ROI_MINUTES_PER_EMPLOYEE=10
ROI_MINUTES_COMPLEX_VAR=6
ROI_MINUTES_ANOMALY=28
ROI_MINUTES_ABSENCE=14
ROI_MANUAL_MINUTES_PER_USER=38
ROI_MAX_RH_HOURS_PER_USER=1.8
ROI_SUBSCRIPTION_MONTHLY=3400
