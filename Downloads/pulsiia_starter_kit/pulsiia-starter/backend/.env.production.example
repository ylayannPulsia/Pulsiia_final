# ═══════════════════════════════════════════════════════════════
# PULSIIA — Variables d'environnement PRODUCTION
# ⚠️  Ne jamais committer ce fichier avec de vraies valeurs !
# ═══════════════════════════════════════════════════════════════

# ── [ÉTAPE 2] Base de données PostgreSQL managée ──────────────
# Railway DB  : postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway
# Supabase    : postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# Neon        : postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pulsiia?sslmode=require"

# ── [ÉTAPE 3] Serveur ─────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── [ÉTAPE 4] URLs (IMPORTANT : adapter à ton vrai domaine) ──
FRONTEND_URL=https://pulsiia.fr
API_URL=https://pulsiia.fr
# Si sous-domaines séparés :
# FRONTEND_URL=https://app.pulsiia.fr
# API_URL=https://api.pulsiia.fr

# ── [ÉTAPE 5] JWT RS256 — Clés PEM inline ─────────────────────
# Commande pour convertir les .pem en une ligne (dans backend/) :
#   node -e "const fs=require('fs'); console.log(fs.readFileSync('./keys/jwt-private.pem','utf8').replace(/\n/g,'\\n'))"
#
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMETA_REMPLACE_MOI\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMETA_REMPLACE_MOI\n-----END PUBLIC KEY-----"
JWT_REFRESH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMETA_REMPLACE_MOI\n-----END PRIVATE KEY-----"
JWT_REFRESH_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMETA_REMPLACE_MOI\n-----END PUBLIC KEY-----"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email transactionnel (invitations collaborateurs, reset MDP…) ─
# Au moins UN fournisseur. Vérifier après deploy : GET /health → "mail":"smtp"
#
# Mailjet — https://app.mailjet.com → API Keys
# En prod (VPS), Pulsiia utilise l'API HTTPS (443), pas le SMTP (587 souvent bloqué).
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_USER=votre_api_key_mailjet
SMTP_PASS=votre_secret_key_mailjet
EMAIL_FROM="Pulsiia <contact@pulsiia.com>"
# L'adresse dans EMAIL_FROM doit être validée chez Mailjet.
# Vérifier : curl "https://pulsiia.fr/health?mail=1" → mailVerify.ok true
#
# Alternative Resend :
# RESEND_API_KEY=re_XXXXX
# EMAIL_FROM="Pulsiia <notifications@pulsiia.fr>"

# ── Push Notifications VAPID ───────────────────────────────────
# Génère avec : npx web-push generate-vapid-keys
VAPID_EMAIL="admin@pulsiia.fr"
VAPID_PUBLIC_KEY=BXXXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=XXXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Uploads (sur VPS → dossier absolu) ────────────────────────
UPLOAD_DIR=/home/pulsiia/app/uploads
MAX_FILE_SIZE_MB=10

# ── Planning IA (Claude Haiku ~0.02€/génération) ──────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXXX
ANTHROPIC_MODEL=claude-haiku-4-5
PLANNING_AI_ENABLED=true

# ── Signature électronique Yousign (optionnel) ────────────────
YOUSIGN_API_KEY=
YOUSIGN_BASE_URL=https://api.yousign.app/v3
YOUSIGN_SIGNATURE_LEVEL=advanced_electronic_signature
YOUSIGN_AUTH_MODE=otp_email

# ── RGPD ───────────────────────────────────────────────────────
TERMS_VERSION="1.0"
PRIVACY_VERSION="1.0"
DATA_RETENTION_DAYS=730
