# Anthropic API (core)
ANTHROPIC_API_KEY=sk-ant-...

# Pulse config (optionnel — valeurs par défaut affichées)
PULSE_MODEL=claude-opus-4-7
PULSE_MODEL_LIGHT=claude-haiku-4-5
PULSE_MAX_TURNS=8
PULSE_MAX_TOKENS=2048

# Audit
AUDIT_RETENTION_DAYS=365

# ─── v2 : Mémoire long terme ───
PULSE_EMBEDDER_PROVIDER=voyage
VOYAGE_API_KEY=pa-...
# OPENAI_API_KEY=sk-...

# ─── v3 : MCP servers ───
# Clé maître AES-256 — générer via :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PULSE_VAULT_KEY=

# Base URL pour OAuth callbacks (production)
PULSIIA_BASE_URL=https://app.pulsiia.com

# Slack OAuth (https://api.slack.com/apps)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
MCP_SLACK_URL=                          # vide → mode mock

# Microsoft Graph / Outlook (https://portal.azure.com → App registrations)
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MCP_OUTLOOK_URL=                        # vide → mode mock

# Silae (auth par API key, pas d'OAuth standard)
SILAE_CLIENT_ID=
SILAE_API_KEY=
MCP_SILAE_URL=                          # vide → mode mock
