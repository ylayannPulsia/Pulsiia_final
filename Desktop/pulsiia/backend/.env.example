# ─── Pulsiia backend — variables d'environnement ───
# Copier en .env et compléter. Ne jamais committer .env.

# ─── App ───
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── Database ───
DATABASE_URL=postgresql://pulsiia:pulsiia_dev@localhost:5432/pulsiia?schema=public

# ─── JWT (RS256) ───
# Générer avec: npm run keys:generate
# Les clés seront placées dans backend/keys/jwt-private.pem et jwt-public.pem
# En prod, charger depuis un secret manager et écrire ces variables au format PEM
# (caractères de fin de ligne = \n littéraux ou multi-ligne)
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=pulsiia
JWT_AUDIENCE=pulsiia-app

# Si tu préfères injecter les clés directement (prod via secret manager) :
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ─── Reset password ───
RESET_TOKEN_TTL_MINUTES=30

# ─── Bcrypt ───
BCRYPT_SALT_ROUNDS=12

# ─── Rate limiting ───
# Valeurs par défaut respectent CDC §9.5
# Auth : 10 / 15 min / IP
# API standard : 200 / min / utilisateur
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_API_MAX=200
RATE_LIMIT_API_WINDOW_MS=60000

# ─── SSO (phase 1b — laisser vide pour l'instant) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_DOMAIN=

# ─── Email (phase 2 — Resend ou SendGrid) ───
RESEND_API_KEY=
EMAIL_FROM=noreply@pulsiia.com

# ─── Push notifications VAPID (phase 3) ───
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dpo@pulsiia.com

# ─── Logging ───
LOG_LEVEL=info
