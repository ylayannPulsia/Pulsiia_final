# ═════════════════════════════════════════════════════════════
# Pulsiia — Production environment
# ═════════════════════════════════════════════════════════════
# Copier ce fichier en .env.production et remplir TOUTES les valeurs
# AVANT le premier déploiement.
#
# CHECKLIST avant go-live :
#  [ ] Tous les secrets générés (voir commandes dans chaque section)
#  [ ] Aucune valeur "CHANGEME" restante (grep -i changeme .env.production)
#  [ ] Fichier en mode 600 (chmod 600 .env.production)
#  [ ] Fichier dans .gitignore et JAMAIS commité
#  [ ] Backup chiffré du fichier dans un secret manager
# ═════════════════════════════════════════════════════════════

# ─── Version applicative ─────────────────────────────────────
PULSIIA_VERSION=1.0.0

# ─── Environnement ───────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# ─── URLs publiques ──────────────────────────────────────────
PULSIIA_BASE_URL=https://app.pulsiia.com
PULSIIA_API_BASE_URL=https://app.pulsiia.com/api
CORS_ORIGIN=https://app.pulsiia.com

# ═════════════════════════════════════════════════════════════
# DATABASE — Postgres + pgvector
# ═════════════════════════════════════════════════════════════
# Génère un password fort :
#   openssl rand -base64 32
DB_USER=pulsiia
DB_PASSWORD=CHANGEME_GENERATE_STRONG_PASSWORD
DB_NAME=pulsiia_prod

# ═════════════════════════════════════════════════════════════
# REDIS — sessions, rate limit, BullMQ
# ═════════════════════════════════════════════════════════════
#   openssl rand -base64 32
REDIS_PASSWORD=CHANGEME_GENERATE_STRONG_PASSWORD

# ═════════════════════════════════════════════════════════════
# SESSION & AUTH (cookies signés Passport.js)
# ═════════════════════════════════════════════════════════════
#   openssl rand -base64 64
SESSION_SECRET=CHANGEME_64_CHARS_RANDOM
JWT_SECRET=CHANGEME_64_CHARS_RANDOM
COOKIE_DOMAIN=.pulsiia.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

# ═════════════════════════════════════════════════════════════
# CHIFFREMENT — Pulse vault (tokens MCP) + RGPD data exports
# ═════════════════════════════════════════════════════════════
# CRITIQUE — perte = toutes les connexions OAuth perdues
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PULSE_VAULT_KEY=CHANGEME_64_HEX_CHARS

# Chiffrement DB-side (champs sensibles type IBAN, SSN si stockés)
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATA_ENCRYPTION_KEY=CHANGEME_64_HEX_CHARS

# ═════════════════════════════════════════════════════════════
# ANTHROPIC API (Pulse core)
# ═════════════════════════════════════════════════════════════
# https://console.anthropic.com → Settings → API Keys
# Recommandé : créer une clé dédiée "pulsiia-prod" avec spending cap
ANTHROPIC_API_KEY=sk-ant-CHANGEME

PULSE_MODEL=claude-opus-4-7
PULSE_MODEL_LIGHT=claude-haiku-4-5
PULSE_MAX_TURNS=8
PULSE_MAX_TOKENS=2048

# ═════════════════════════════════════════════════════════════
# EMBEDDINGS — Voyage AI (mémoire long terme Pulse)
# ═════════════════════════════════════════════════════════════
# https://www.voyageai.com → API Keys
PULSE_EMBEDDER_PROVIDER=voyage
VOYAGE_API_KEY=pa-CHANGEME

# ═════════════════════════════════════════════════════════════
# EMAIL — Resend (recommandé) ou SendGrid
# ═════════════════════════════════════════════════════════════
# https://resend.com → API Keys
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_CHANGEME
EMAIL_FROM="Pulsiia <noreply@pulsiia.com>"
EMAIL_FROM_NAME=Pulsiia
EMAIL_SUPPORT=support@pulsiia.com

# ═════════════════════════════════════════════════════════════
# OAuth SSO entrants (Passport.js — connexion utilisateurs Pulsiia)
# ═════════════════════════════════════════════════════════════
# Google Workspace
GOOGLE_CLIENT_ID=CHANGEME
GOOGLE_CLIENT_SECRET=CHANGEME
GOOGLE_CALLBACK_URL=https://app.pulsiia.com/auth/google/callback

# Microsoft Azure AD
MS_CLIENT_ID=CHANGEME
MS_CLIENT_SECRET=CHANGEME
MS_TENANT_ID=common
MS_CALLBACK_URL=https://app.pulsiia.com/auth/microsoft/callback

# Okta SAML (optionnel)
# OKTA_ENTRY_POINT=
# OKTA_ISSUER=
# OKTA_CERT=

# ═════════════════════════════════════════════════════════════
# MCP SERVERS — Slack / Outlook / Silae
# ═════════════════════════════════════════════════════════════
# Si vide → mode mock (démo) automatiquement.

# ─── Slack ─────────────────────────────────────────────────
# https://api.slack.com/apps → Create app → OAuth & Permissions
# Redirect URL : https://app.pulsiia.com/api/pulse/mcp/callback/slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
MCP_SLACK_URL=

# ─── Microsoft Graph (Outlook) ─────────────────────────────
# https://portal.azure.com → App registrations → New
# Redirect URI : https://app.pulsiia.com/api/pulse/mcp/callback/outlook
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MCP_OUTLOOK_URL=

# ─── Silae (API key, pas d'OAuth standard) ─────────────────
SILAE_CLIENT_ID=
SILAE_API_KEY=
MCP_SILAE_URL=

# ═════════════════════════════════════════════════════════════
# PWA — Web Push (notifications proactives)
# ═════════════════════════════════════════════════════════════
# Génère VAPID keys :
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGEME
VAPID_PRIVATE_KEY=CHANGEME
VAPID_SUBJECT=mailto:support@pulsiia.com

# ═════════════════════════════════════════════════════════════
# OBSERVABILITÉ
# ═════════════════════════════════════════════════════════════
# Sentry — error tracking (https://sentry.io)
SENTRY_DSN=https://CHANGEME@CHANGEME.ingest.sentry.io/CHANGEME
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Better Stack / UptimeRobot — uptime monitoring (URL externe)
# (configuré côté provider, pas en env)

# Logtail / Loki / autre — log aggregation (optionnel)
# LOGTAIL_TOKEN=

# ═════════════════════════════════════════════════════════════
# BACKUPS — S3-compatible (optionnel mais recommandé)
# ═════════════════════════════════════════════════════════════
# Scaleway Object Storage / OVH / Backblaze B2 / etc.
BACKUP_S3_ENDPOINT=https://s3.fr-par.scw.cloud
BACKUP_S3_BUCKET=pulsiia-backups-prod
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_RETENTION_DAYS=30

# ═════════════════════════════════════════════════════════════
# DIVERS
# ═════════════════════════════════════════════════════════════
AUDIT_RETENTION_DAYS=365
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Feature flags — pour activer/désactiver à chaud
FEATURE_PULSE_MEMORY=true
FEATURE_PULSE_PROACTIVE_ALERTS=true
FEATURE_PULSE_MCP=true
